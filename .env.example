# =============================================================================
# PLACEHOLDER VALUES ONLY — copy to .env.local and replace with real values.
# Never commit .env or .env.local (they are gitignored).
# =============================================================================

# PostgreSQL — Supabase (Project Settings → Database → Connection string → URI)
#
# For the RUNNING APP (use Transaction pooler, port 6543):
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# For db:push MIGRATIONS (use Session/Direct mode, port 5432 — avoids drizzle-kit bugs):
# DATABASE_URL_MIGRATIONS=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
DATABASE_URL=postgresql://user:password@host:5432/ipo_tracker
DATABASE_URL_MIGRATIONS=

# Required by SEC — requests without this return 403
# Use your real name and email: "YourAppName you@yourdomain.com"
SEC_USER_AGENT="IPOTracker you@email.com"

# LLM for date curation and risk analysis (optional — fallback logic used without it)
OPENAI_API_KEY=

# Market data: yahoo (free, dev) or polygon (production)
MARKET_DATA_PROVIDER=yahoo
POLYGON_API_KEY=

# Inngest (auto-set via Vercel marketplace integration)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# App URL for production
NEXT_PUBLIC_APP_URL=http://localhost:3000
